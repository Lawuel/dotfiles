{
  "layer": "top",
  "position": "top",
  "modules-left": ["group/power", "bluetooth", "network", "mpris", "cava"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "wireplumber",
    "backlight",
    "cpu",
    "memory",
    "user",
    "clock"
  ],

  "group/power": {
    "orientation": "horizontal",
    "modules": [
      "custom/show-power-options",
      "custom/suspend",
      "custom/reboot",
      "custom/shutdown",
      "custom/logout"
    ],
    "drawer": {
      "click-to-reveal": true,
      "transition-left-to-right": true
    }
  },

  "custom/show-power-options": {
    "format": "َ°€„",
    "tooltip": false
  },

  "custom/suspend": {
    "format": "َ°¤„",
    "on-click": "systemctl suspend",
    "tooltip-format": "suspend"
  },

  "custom/reboot": {
    "format": "َ°œ‰",
    "on-click": "reboot",
    "tooltip-format": "reboot"
  },

  "custom/shutdown": {
    "format": "َ°گ¥",
    "on-click": "poweroff",
    "tooltip-format": "shutdown"
  },

  "custom/logout": {
    "format": "َ°چƒ",
    "on-click": "hyprctl dispatch exit",
    "tooltip-format": "logout"
  },

  "bluetooth": {
    "on-click": "blueman-manager",
    "format": "َ°‚¯",
    "format-off": "َ°‚²",
    "format-disabled": "َ°‚²",
    "format-connected": "َ°‚±",
    "tooltip-format": "bluetooth",
    "tooltip-format-off": "off",
    "tooltip-format-disabled": "disabled",
    "tooltip-format-connected": "{device_alias}"
  },

  "network": {
    "on-click": "nm-connection-editor",
    "format-disconnected": "َ°¤®",
    "tooltip-format": "{essid}",
    "format": "{icon}",
    "format-icons": ["َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"]
  },

  "mpris": {
    "format": "َ°´™",
    "format-paused": "{status_icon}",
    "format-playing": "{status_icon}",
    "status-icons": {
      "paused": "َ°گٹ",
      "playing": "َ°ڈ¤"
    },
    "tooltip-format": "{artist} | {title}"
  },

  "cava": {
    "cava_config": "~/.config/cava/config"
  },

  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "urgent": "َ°®•",
      "active": "َ°‌¥",
      "default": "َ°‌¦"
    }
  },
  "wireplumber": {
    "on-click": "pavucontrol",
    "format-muted": "َ°‌ں {volume}%",
    "format": "{icon} {volume}%",
    "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"]
  },

  "backlight": {
    "device": "intel_backlight",
    "tooltip": false,
    "format": "{icon} {percent}%",
    "format-icons": ["َ±©ژ", "َ±©ڈ", "َ±©گ", "َ±©‘", "َ±©’", "َ±©“", "َ±©”", "َ±©•", "َ±©–", "َ°›¨"]
  },

  "cpu": {
    "interval": 15,
    "format": "َ°™… {usage}%"
  },

  "memory": {
    "interval": 15,
    "format": "َ°Œ¨ {percentage}%"
  },

  "user": {
    "format": "{work_H}:{work_M}"
  },

  "clock": {
    "format": "{:%I:%M}",
    "tooltip-format": "{:%a %b %d, %Y}"
  }
}
